# ===========================================
# Movie Dubber - cPanel Production Config
# ===========================================
# This file is copied to .env on each deploy.
# Edit this file on the server, NOT .env directly.
# ===========================================

# Application Settings
APP_NAME="Movie Dubber"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://dubbing.uz
APP_KEY=

# Database Configuration (cPanel MySQL)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_cpanel_db_name
DB_USERNAME=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

# Queue & Cache (database — no Redis on cPanel)
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_CONNECTION=mysql

# Filesystem
FILESYSTEM_DISK=local

# ===========================================
# External API Keys (REQUIRED)
# ===========================================

# Hugging Face Token
HF_TOKEN=your_huggingface_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# RunPod GPU Services
# ===========================================
WHISPERX_SERVICE_URL=https://your-pod-id-8002.proxy.runpod.net
DEMUCS_SERVICE_URL=https://your-pod-id-8000.proxy.runpod.net
OPENVOICE_SERVICE_URL=https://your-pod-id-8005.proxy.runpod.net

# ===========================================
# Optional Settings
# ===========================================

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Admin Panel Password
ADMIN_PASSWORD=

# Session
SESSION_LIFETIME=120
